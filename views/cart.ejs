<%- include('./partials/user-header') %>

<div class="w-full min-h-screen bg-[#FCFCFC] font-['Plus_Jakarta_Sans',sans-serif] pb-20">
    
    <div class="w-full py-12 px-6 md:px-20 border-b border-zinc-100 bg-white">
        <h1 class="text-4xl font-black tracking-tighter text-zinc-900 uppercase italic">Your Collection</h1>
        <p class="text-zinc-500 text-sm mt-2">You have <%= user.cart.length %> items in your cart.</p>
    </div>

    <% if (user.cart.length === 0) { %>
        <div class="w-full h-[60vh] flex flex-col items-center justify-center text-center px-6">
            <div class="w-32 h-32 bg-zinc-100 rounded-full flex items-center justify-center mb-6">
                <i class="ri-shopping-cart-2-line text-5xl text-zinc-300"></i>
            </div>
            <h2 class="text-2xl font-black text-zinc-900 uppercase tracking-tight">Your Cart is Empty</h2>
            <p class="text-zinc-500 mt-2 mb-8 max-w-xs">Looks like you haven't added any premium carry to your collection yet.</p>
            <a href="/shop" class="px-10 py-4 bg-black text-white font-bold rounded-full hover:bg-amber-500 hover:text-black transition-all">
                Return to Shop
            </a>
        </div>
    <% } else { %>

        <div class="max-w-7xl mx-auto px-6 md:px-10 py-16 grid grid-cols-1 lg:grid-cols-12 gap-16">
            
            <div class="lg:col-span-7 space-y-10">
                <% user.cart.forEach(function(item){ %>
                    <div class="group relative flex flex-col md:flex-row items-stretch gap-8 bg-white p-6 rounded-[2.5rem] border border-zinc-100 hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.05)] transition-all duration-500">
                        
                        <div class="w-full md:w-64 h-72 rounded-[2rem] overflow-hidden relative shadow-inner" style="background-color: <%= item.bgcolor %>">
                            <img class="w-full h-full object-contain p-6 group-hover:scale-110 transition-transform duration-700" 
                                 src="data:image/jpeg;base64,<%= item.image.toString('base64') %>" alt="<%= item.name %>">
                            
                            <a href="/removefromcart/<%= item._id %>" class="absolute top-4 right-4 w-10 h-10 bg-white/90 backdrop-blur-md rounded-full flex items-center justify-center text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-lg">
                                <i class="ri-delete-bin-6-line"></i>
                            </a>
                        </div>

                        <div class="flex-1 flex flex-col justify-between py-2">
                            <div>
                                <div class="flex justify-between items-start mb-2">
                                    <h3 class="text-2xl font-black tracking-tight text-zinc-900 uppercase italic leading-none"><%= item.name %></h3>
                                    <span class="text-xs font-bold px-3 py-1 bg-zinc-100 rounded-full text-zinc-500">QTY: 01</span>
                                </div>
                                <p class="text-zinc-400 text-xs uppercase tracking-[0.2em] font-bold">Premium Grade Carry</p>
                                
                                <div class="flex gap-2 mt-4">
                                    <div class="w-3 h-3 rounded-full border border-zinc-200 shadow-sm" style="background-color: <%= item.panelcolor %>"></div>
                                    <div class="w-3 h-3 rounded-full border border-zinc-200 shadow-sm" style="background-color: <%= item.textcolor %>"></div>
                                </div>
                            </div>

                            <div class="mt-8 md:mt-0 pt-6 border-t border-zinc-50 flex justify-between items-end">
                                <div>
                                    <p class="text-[10px] font-black uppercase text-zinc-400 tracking-widest mb-1">Item Total</p>
                                    <h4 class="text-2xl font-black tracking-tighter">₹ <%= Number(item.price) - Number(item.discount) %></h4>
                                </div>
                                <% if(item.discount > 0) { %>
                                    <span class="text-xs font-bold text-emerald-500">Saved ₹<%= item.discount %></span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="lg:col-span-5">
                <div class="sticky top-32 bg-white rounded-[3rem] p-10 border border-zinc-100 shadow-[0_40px_100px_-20px_rgba(0,0,0,0.05)]">
                    <h3 class="text-xl font-black uppercase tracking-tighter mb-8 border-b border-zinc-100 pb-4 italic">Order Summary</h3>
                    
                    <div class="space-y-4 mb-10">
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-zinc-500 font-medium">Subtotal MRP</span>
                            <span class="text-zinc-900 font-bold">₹ <%= cartTotal - 20 %></span>
                        </div>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-zinc-500 font-medium">Platform Handling</span>
                            <span class="text-zinc-900 font-bold">₹ 20</span>
                        </div>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-zinc-500 font-medium">Shipping</span>
                            <span class="text-emerald-500 font-black uppercase tracking-widest text-[10px]">Free</span>
                        </div>
                    </div>

                    <div class="pt-6 border-t border-zinc-200 flex justify-between items-center mb-10">
                        <div>
                            <p class="text-[10px] font-black uppercase text-zinc-400 tracking-widest">Total Amount</p>
                            <h2 class="text-4xl font-black tracking-tighter text-zinc-900 italic">₹ <%= cartTotal %></h2>
                        </div>
                        <div class="w-12 h-12 bg-amber-100 rounded-2xl flex items-center justify-center text-amber-600">
                            <i class="ri-bank-card-line text-2xl"></i>
                        </div>
                    </div>

                    <button class="w-full bg-black text-white py-6 rounded-2xl font-black uppercase tracking-[0.2em] text-xs hover:bg-amber-500 hover:text-black transition-all shadow-xl active:scale-[0.98]">
                        Proceed to Checkout
                    </button>

                    <div class="mt-8 flex items-center justify-center gap-4 opacity-30 grayscale">
                        <i class="ri-visa-line text-3xl"></i>
                        <i class="ri-mastercard-line text-3xl"></i>
                        <i class="ri-paypal-line text-3xl"></i>
                    </div>
                </div>
            </div>

        </div>

    <% } %>
</div>

<%- include('./partials/user-footer') %>
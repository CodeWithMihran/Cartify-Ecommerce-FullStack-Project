<%- include('./partials/user-header') %>

<div class="min-h-screen flex bg-[#F8F9FA] font-['Plus_Jakarta_Sans',sans-serif]">
    
    <aside class="w-72 bg-[#0A0A0A] text-white p-10 hidden lg:flex flex-col justify-between sticky top-0 h-screen border-r border-white/5">
        <div>
            <div class="flex items-center gap-3 mb-16">
                <div class="w-10 h-10 bg-amber-500 rounded-xl flex items-center justify-center">
                    <i class="ri-dashboard-3-fill text-black text-xl"></i>
                </div>
                <div>
                    <h2 class="text-xl font-black tracking-tighter uppercase italic">Admin</h2>
                    <p class="text-[10px] text-zinc-500 uppercase tracking-widest font-bold">Cartify Panel</p>
                </div>
            </div>

            <nav class="space-y-2">
                <p class="text-[10px] uppercase tracking-[0.3em] text-zinc-600 font-black mb-4">Inventory</p>
                <a href="/owners/admin" class="flex items-center gap-4 px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-amber-500 font-bold transition-all">
                    <i class="ri-layout-grid-fill"></i> All Products
                </a>
                <a href="/owners/admin" class="flex items-center gap-4 px-4 py-3 text-zinc-400 hover:bg-white/5 hover:text-white rounded-xl transition-all group">
                    <i class="ri-add-circle-line group-hover:text-amber-500"></i> Create New
                </a>
                
                <p class="text-[10px] uppercase tracking-[0.3em] text-zinc-600 font-black mb-4 mt-10">Sales</p>
                <a href="#" class="flex items-center gap-4 px-4 py-3 text-zinc-400 hover:bg-white/5 hover:text-white rounded-xl transition-all">
                    <i class="ri-shopping-bag-3-line"></i> Orders
                </a>
                <a href="#" class="flex items-center gap-4 px-4 py-3 text-zinc-400 hover:bg-white/5 hover:text-white rounded-xl transition-all">
                    <i class="ri-group-line"></i> Customers
                </a>
            </nav>
        </div>

        <div class="pt-10 border-t border-white/5">
            <a href="/logout" class="flex items-center justify-center gap-2 w-full bg-red-500/10 text-red-500 border border-red-500/20 py-4 rounded-2xl font-bold uppercase tracking-widest text-[11px] hover:bg-red-500 hover:text-white transition-all">
                <i class="ri-logout-box-r-line"></i> End Session
            </a>
        </div>
    </aside>

    <main class="flex-1 p-8 md:p-14 overflow-y-auto">
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
            <div>
                <h1 class="text-4xl font-black tracking-tighter text-zinc-900 uppercase italic">Collection Manager</h1>
                <p class="text-zinc-500 font-light mt-1 text-sm">Review and manage your premium inventory listings.</p>
            </div>
            <div class="flex items-center gap-4">
                <button class="bg-white border border-zinc-200 text-zinc-600 px-6 py-3 rounded-xl font-bold text-xs uppercase tracking-widest hover:border-black transition-all">
                    <i class="ri-download-2-line mr-2"></i> Export CSV
                </button>
                <a href="/owners/admin" class="bg-black text-white px-8 py-3 rounded-xl font-bold text-xs uppercase tracking-widest hover:bg-amber-500 hover:text-black transition-all shadow-xl">
                    Add Product
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="bg-white p-8 rounded-[2.5rem] border border-zinc-100 shadow-sm">
                <span class="text-[10px] font-black uppercase tracking-widest text-zinc-400">Total Stock</span>
                <h3 class="text-3xl font-black mt-2 tracking-tighter">142 <span class="text-xs font-medium text-emerald-500">+12%</span></h3>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] border border-zinc-100 shadow-sm">
                <span class="text-[10px] font-black uppercase tracking-widest text-zinc-400">Revenue (MTD)</span>
                <h3 class="text-3xl font-black mt-2 tracking-tighter">₹84,200</h3>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] border border-amber-100 bg-amber-50/30">
                <span class="text-[10px] font-black uppercase tracking-widest text-amber-600">Pending Orders</span>
                <h3 class="text-3xl font-black mt-2 tracking-tighter text-amber-900">08</h3>
            </div>
        </div>

        <div class="flex justify-between items-end mb-8 border-b border-zinc-200 pb-4">
            <h2 class="text-xs font-black uppercase tracking-[0.3em] text-zinc-400">Current Catalog</h2>
            <button class="text-red-500 font-bold text-[10px] uppercase tracking-widest hover:underline">Flush All Inventory</button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            <% /* Note: Later you will use: for(let product of products) */ %>
            <% for(let i=0; i < 8; i++) { %>
                <div class="group bg-white rounded-[2rem] border border-zinc-100 overflow-hidden hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
                    <div class="h-60 bg-[#F3F3F3] relative flex items-center justify-center overflow-hidden">
                        <i class="ri-image-line text-4xl text-zinc-300"></i>
                        <div class="absolute top-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-x-10 group-hover:translate-x-0">
                            <button class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-lg hover:bg-black hover:text-white transition-all"><i class="ri-pencil-line"></i></button>
                            <button class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-lg hover:bg-red-500 hover:text-white transition-all"><i class="ri-delete-bin-line"></i></button>
                        </div>
                    </div>
                    
                    <div class="p-8">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <h3 class="text-lg font-black tracking-tight text-zinc-900 group-hover:text-amber-600 transition-colors uppercase italic">Legacy Duffel</h3>
                                <p class="text-zinc-400 text-xs uppercase tracking-widest font-bold">Category: Duffel</p>
                            </div>
                            <span class="px-3 py-1 bg-zinc-100 rounded-full text-[10px] font-black uppercase tracking-tighter">In Stock</span>
                        </div>
                        <div class="flex justify-between items-center pt-6 border-t border-zinc-50">
                            <span class="text-xl font-black tracking-tighter">₹ 4,499</span>
                            <div class="flex gap-1">
                                <div class="w-3 h-3 rounded-full bg-zinc-900 border border-zinc-200"></div>
                                <div class="w-3 h-3 rounded-full bg-amber-500 border border-zinc-200"></div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>

    </main>
</div>

<%- include('./partials/footer') %>
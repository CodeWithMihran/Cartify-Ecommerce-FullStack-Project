<%- include('./partials/header') %>

<div class="w-full bg-[#FCFCFC] font-['Inter',sans-serif] selection:bg-amber-200">

    <div class="w-full bg-black py-2 px-4 overflow-hidden relative">
        <div class="flex items-center justify-center gap-10 animate-marquee whitespace-nowrap">
            <span class="text-[10px] uppercase tracking-[0.3em] text-white font-medium">✨ Premium Leather Collection 2026 Out Now</span>
            <span class="text-[10px] uppercase tracking-[0.3em] text-amber-400 font-medium italic">Free Shipping on orders above ₹4999</span>
            <span class="text-[10px] uppercase tracking-[0.3em] text-white font-medium">✨ Handcrafted in India</span>
        </div>
    </div>

    <section class="relative h-[90vh] w-full flex items-center justify-center overflow-hidden bg-zinc-900">
        <div class="absolute inset-0 opacity-60">
            <img src="https://images.unsplash.com/photo-1547949003-9792a18a2601?q=80&w=2070&auto=format&fit=crop" 
                 class="w-full h-full object-cover" alt="Luxury Bag Hero">
        </div>
        <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/80"></div>

        <div class="relative z-10 text-center px-6">
            <span class="text-amber-500 font-bold tracking-[0.5em] text-sm mb-4 block uppercase animate-pulse">Redefining Utility</span>
            <h1 class="text-6xl md:text-9xl font-black text-white tracking-tighter leading-none mb-8">
                CARTIFY<span class="text-amber-500">.</span>
            </h1>
            <p class="text-zinc-300 text-lg md:text-xl max-w-2xl mx-auto font-light leading-relaxed mb-10">
                Engineering the perfect carry for the modern explorer. From boardroom to back-country, carry excellence in every stitch.
            </p>
            <div class="flex flex-col md:flex-row items-center justify-center gap-4">
                <a href="#auth-section" class="px-10 py-4 bg-white text-black font-bold rounded-full hover:bg-amber-500 transition-all hover:scale-105 duration-300">
                    Get Started
                </a>
                <a href="#features" class="px-10 py-4 border border-white/30 text-white font-bold rounded-full hover:bg-white/10 backdrop-blur-sm transition-all">
                    Discover Quality
                </a>
            </div>
        </div>

        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
            <span class="text-[10px] text-zinc-500 uppercase tracking-widest">Scroll Down</span>
            <div class="w-[1px] h-12 bg-gradient-to-b from-zinc-500 to-transparent"></div>
        </div>
    </section>

    <section id="features" class="py-24 px-6 max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 border-b border-zinc-100">
        <div class="group text-center">
            <div class="w-16 h-16 bg-zinc-100 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-amber-500 transition-colors duration-500">
                <i class="ri-shield-check-line text-3xl group-hover:text-white"></i>
            </div>
            <h3 class="text-xl font-bold mb-3 uppercase tracking-tight">Indestructible Build</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">Reinforced double-stitching and premium industrial zippers tested for 10,000+ pulls.</p>
        </div>
        <div class="group text-center">
            <div class="w-16 h-16 bg-zinc-100 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-amber-500 transition-colors duration-500">
                <i class="ri-leaf-line text-3xl group-hover:text-white"></i>
            </div>
            <h3 class="text-xl font-bold mb-3 uppercase tracking-tight">Ethical Sourcing</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">100% Top-grain sustainable leather, tanned with zero harmful chemicals.</p>
        </div>
        <div class="group text-center">
            <div class="w-16 h-16 bg-zinc-100 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-amber-500 transition-colors duration-500">
                <i class="ri-customer-service-2-line text-3xl group-hover:text-white"></i>
            </div>
            <h3 class="text-xl font-bold mb-3 uppercase tracking-tight">24/7 Concierge</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">Our dedicated support team is here to help you find your perfect daily companion.</p>
        </div>
    </section>

    <section id="auth-section" class="py-24 px-6 bg-white flex items-center justify-center relative">
        
        <% if(error && error.length > 0){ %>
            <div class="absolute top-10 bg-red-50 text-red-600 px-6 py-3 rounded-full flex items-center gap-2 border border-red-200 animate-pulse">
                <i class="ri-error-warning-fill"></i>
                <span class="text-sm font-bold uppercase tracking-tighter"><%= error %></span>
            </div>
        <% } %>

        <div class="w-full max-w-xl">
            <div class="bg-white rounded-[2rem] p-10 md:p-14 shadow-[0_40px_100px_-20px_rgba(0,0,0,0.08)] border border-zinc-50">
                
                <div class="flex justify-center gap-10 mb-12 border-b border-zinc-100">
                    <button id="login-btn" onclick="toggleAuth('login')" class="pb-4 text-xs font-black uppercase tracking-[0.2em] border-b-2 border-black">Login</button>
                    <button id="register-btn" onclick="toggleAuth('register')" class="pb-4 text-xs font-black uppercase tracking-[0.2em] border-b-2 border-transparent text-zinc-300">Join Us</button>
                </div>

                <div id="login-area" class="transition-all duration-500">
                    <div class="mb-10">
                        <h2 class="text-3xl font-black tracking-tight text-zinc-900 mb-2 uppercase">Welcome Back</h2>
                        <p class="text-zinc-400 font-light">Enter your credentials to manage your collection.</p>
                    </div>
                    <form action="/users/login" method="post" class="space-y-6">
                        <div class="relative">
                            <label class="text-[10px] font-black uppercase text-zinc-400 absolute -top-2 left-4 bg-white px-2">Email</label>
                            <input class="w-full px-6 py-4 rounded-xl border border-zinc-200 focus:border-black outline-none transition-all placeholder:text-zinc-200" 
                                   type="email" name="email" placeholder="john@example.com" required>
                        </div>
                        <div class="relative">
                            <label class="text-[10px] font-black uppercase text-zinc-400 absolute -top-2 left-4 bg-white px-2">Password</label>
                            <input class="w-full px-6 py-4 rounded-xl border border-zinc-200 focus:border-black outline-none transition-all placeholder:text-zinc-200" 
                                   type="password" name="password" placeholder="••••••••" required>
                        </div>
                        <button class="w-full bg-black text-white py-5 rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-amber-500 hover:text-black transition-all shadow-xl active:scale-95">
                            Secure Login
                        </button>
                    </form>
                </div>

                <div id="register-area" class="hidden transition-all duration-500">
                    <div class="mb-10">
                        <h2 class="text-3xl font-black tracking-tight text-zinc-900 mb-2 uppercase">Become a Member</h2>
                        <p class="text-zinc-400 font-light">Join the elite circle of premium carry enthusiasts.</p>
                    </div>
                    <form action="/users/register" method="post" class="space-y-6">
                        <div class="relative">
                            <label class="text-[10px] font-black uppercase text-zinc-400 absolute -top-2 left-4 bg-white px-2">Full Name</label>
                            <input class="w-full px-6 py-4 rounded-xl border border-zinc-200 focus:border-black outline-none transition-all placeholder:text-zinc-200" 
                                   type="text" name="fullname" placeholder="Md Mihran Sohail" required>
                        </div>
                        <div class="relative">
                            <label class="text-[10px] font-black uppercase text-zinc-400 absolute -top-2 left-4 bg-white px-2">Email</label>
                            <input class="w-full px-6 py-4 rounded-xl border border-zinc-200 focus:border-black outline-none transition-all placeholder:text-zinc-200" 
                                   type="email" name="email" placeholder="john@example.com" required>
                        </div>
                        <div class="relative">
                            <label class="text-[10px] font-black uppercase text-zinc-400 absolute -top-2 left-4 bg-white px-2">Password</label>
                            <input class="w-full px-6 py-4 rounded-xl border border-zinc-200 focus:border-black outline-none transition-all placeholder:text-zinc-200" 
                                   type="password" name="password" placeholder="••••••••" required>
                        </div>
                        <button class="w-full bg-black text-white py-5 rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-amber-500 hover:text-black transition-all shadow-xl active:scale-95">
                            Create Account
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </section>

    <section class="py-24 bg-[#0a0a0a] text-white">
        <div class="max-w-4xl mx-auto text-center px-6">
            <i class="ri-double-quotes-l text-5xl text-amber-500 opacity-50 mb-6 block"></i>
            <h2 class="text-3xl md:text-4xl font-light italic leading-relaxed mb-10">
                "The most versatile backpack I've ever owned. From client meetings in London to a weekend hike in the Lake District, it never feels out of place."
            </h2>
            <div class="flex items-center justify-center gap-4">
                <div class="w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700"></div>
                <div class="text-left">
                    <p class="font-bold uppercase tracking-widest text-sm">Alexander Pierce</p>
                    <p class="text-zinc-500 text-xs">Architect & Travel Vlogger</p>
                </div>
            </div>
        </div>
    </section>

</div>

<style>
    @keyframes marquee {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .animate-marquee {
        animation: marquee 20s linear infinite;
        display: inline-flex;
        width: 200%;
    }
    html {
        scroll-behavior: smooth;
    }
</style>

<script>
    function toggleAuth(mode) {
        const loginArea = document.getElementById('login-area');
        const registerArea = document.getElementById('register-area');
        const loginBtn = document.getElementById('login-btn');
        const registerBtn = document.getElementById('register-btn');

        if (mode === 'login') {
            loginArea.classList.remove('hidden');
            registerArea.classList.add('hidden');
            loginBtn.classList.add('border-black', 'text-black');
            loginBtn.classList.remove('border-transparent', 'text-zinc-300');
            registerBtn.classList.remove('border-black', 'text-black');
            registerBtn.classList.add('border-transparent', 'text-zinc-300');
        } else {
            registerArea.classList.remove('hidden');
            loginArea.classList.add('hidden');
            registerBtn.classList.add('border-black', 'text-black');
            registerBtn.classList.remove('border-transparent', 'text-zinc-300');
            loginBtn.classList.remove('border-black', 'text-black');
            loginBtn.classList.add('border-transparent', 'text-zinc-300');
        }
    }
</script>

<%- include('./partials/footer') %>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Cartify | Premium Carry</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            scroll-behavior: smooth;
        }
        /* Soft Blur for the sticky nav */
        .glass-nav {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }
        .nav-link-active {
            color: #000;
            font-weight: 800;
        }
        .nav-link-active::after {
            content: '';
            display: block;
            width: 4px;
            height: 4px;
            background: #f59e0b; /* Amber 500 */
            border-radius: 50%;
            margin: 2px auto 0;
        }
    </style>
</head>

<body class="bg-[#FCFCFC]">

    <nav class="fixed top-0 left-0 w-full z-[100] glass-nav transition-all duration-300">
        <div class="max-w-[1600px] mx-auto px-6 md:px-12 h-20 flex items-center justify-between">
            
            <a href="/shop" class="flex items-center gap-3 group">
                <div class="w-10 h-10 bg-black rounded-xl flex items-center justify-center transition-all duration-500 group-hover:bg-amber-500 group-hover:rotate-12 shadow-lg">
                    <i class="ri-handbag-fill text-white group-hover:text-black text-xl transition-colors"></i>
                </div>
                <div class="flex flex-col">
                    <span class="text-xl font-black text-black tracking-tighter uppercase italic leading-none">Cartify</span>
                    <span class="text-[9px] font-bold text-zinc-400 uppercase tracking-[0.2em] mt-1">Premium Shop</span>
                </div>
            </a>

            <div class="hidden md:flex items-center gap-10">
                <a href="/shop" class="text-[11px] font-black uppercase tracking-[0.2em] text-zinc-400 hover:text-black transition-all flex flex-col items-center group">
                    <span>Shop</span>
                    <div class="w-1 h-1 bg-amber-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity mt-1"></div>
                </a>
                <a href="#" class="text-[11px] font-black uppercase tracking-[0.2em] text-zinc-400 hover:text-black transition-all flex flex-col items-center group">
                    <span>New Arrivals</span>
                    <div class="w-1 h-1 bg-amber-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity mt-1"></div>
                </a>
                <a href="#" class="text-[11px] font-black uppercase tracking-[0.2em] text-zinc-400 hover:text-black transition-all flex flex-col items-center group">
                    <span>Account</span>
                    <div class="w-1 h-1 bg-amber-500 rounded-full opacity-0 group-hover:opacity-100 transition-opacity mt-1"></div>
                </a>
            </div>

            <div class="flex items-center gap-4 md:gap-8">
                
                <button class="text-zinc-400 hover:text-black transition-colors hidden sm:block">
                    <i class="ri-search-line text-xl"></i>
                </button>

                <a href="/cart" class="relative group p-2">
                    <i class="ri-shopping-bag-3-line text-2xl text-zinc-900 group-hover:text-amber-600 transition-colors"></i>
                    <% if(user && user.cart && user.cart.length > 0) { %>
                        <span class="absolute top-0 right-0 w-5 h-5 bg-black text-white text-[10px] font-black rounded-full flex items-center justify-center border-2 border-white shadow-sm">
                            <%= user.cart.length %>
                        </span>
                    <% } %>
                </a>

                <div class="h-10 w-[1px] bg-zinc-100 mx-2 hidden md:block"></div>
                
                <div class="flex items-center gap-4">
                    <div class="hidden md:flex flex-col items-end">
                        <span class="text-[10px] font-black text-zinc-900 uppercase tracking-tighter">
                            <%= user.fullname.split(' ')[0] %> </span>
                        <span class="text-[9px] font-bold text-emerald-500 uppercase tracking-widest">Active Member</span>
                    </div>
                    
                    <div class="relative group cursor-pointer">
                        <div class="w-10 h-10 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center text-zinc-400 overflow-hidden group-hover:border-amber-500 transition-all">
                            <% if(user.picture) { %>
                                <img src="<%= user.picture %>" alt="User" class="w-full h-full object-cover">
                            <% } else { %>
                                <i class="ri-user-3-line text-lg"></i>
                            <% } %>
                        </div>
                        
                        <div class="absolute right-0 top-12 w-48 bg-white rounded-2xl shadow-2xl border border-zinc-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 p-2">
                            <a href="/logout" class="flex items-center gap-3 px-4 py-3 text-red-500 hover:bg-red-50 rounded-xl transition-all font-bold text-xs uppercase tracking-widest">
                                <i class="ri-logout-box-r-line"></i> Logout
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </nav>

    <div class="h-20"></div>